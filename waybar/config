{
	"layer": "top", // Waybar at top layer
		"position": "top", // Waybar position (top|bottom|left|right)

		"height": 30, // Waybar height (to be removed for auto height)
									// "spacing": 1, // Gaps between modules (4px)
		"margin-bottom": 0,

		// Choose the order of the modules

		"modules-left": ["hyprland/workspaces"],
		"modules-center": ["clock"],
		"modules-right": ["bluetooth", "network", "pulseaudio", "battery", "cpu", "memory"],
		// "modules-center": ["hyprland/window"],
		// "modules-right": ["bluetooth", "network", "pulseaudio", "cpu", "memory", "battery", "clock"],

		// Modules configuration

		"custom/updates": {
			"format": "´éź  {}",
			"tooltip-format": "{}",
			"escape": true,
			"return-type": "json",
			"exec": "~/.config/scripts/updates.sh",
			"restart-interval": 3600,
			"tooltip": false
		},

		"hyprland/workspaces": {
			"disable-scroll": true,
			"all-outputs": true,
			"active-only": false,
			"persistent-workspaces": { "*": 5 },
			"warp-on-scroll": false,
			"format": "",
			// "format": "{name}: {icon}",
			"format-icons": {
				"1": "´äá",
				"2": "´ëĘ",
				// "3": "´äí",
				// "4": "´ć╝",
				// "5": "´üÁ",
				"urgent": "´ü¬",
				"focused": "´ćĺ",
				"default": "´äĹ"
			}
		},

		"hyprland/window": {
			"format": "{title}",
			"max-length": 40,
			"separate-outputs": true,
			"rewrite": {
				"(.*) - Google Chrome": "$1",
				"shivansh@ibm5100:(.*)": "$1",
				"rofi - Applications:": "Applications",
				"(.*) - Thunar": "$1",
			}
		},

		// Group Hardware
		"group/hardware": {
			"orientation": "inherit",
			"drawer": {
				"transition-duration": 300,
				"children-class": "not-memory",
				"transition-left-to-right": false
			},        
			"modules": [
				"memory",
			"battery",
			"cpu",
			]
		},

		"clock": {
			// "timezone": "America/New_York",
			"format": "{:%d %b | %A | %I:%M %p}",
			"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
			"on-click": "while read; do dunstctl history-pop; done <<<$(dunstctl history|grep '\"id\" :')",
		},

		"cpu": {
			"format": "´őŤ  {usage}%",
			"tooltip": false
		},

		"memory": {
			"format": "´âë  {}%"
		},

		"battery": {
			"states": {
				// "good": 95,
				"warning": 30,
				"critical": 15
			},
			"format": "{icon}  {capacity}%",
			"format-charging": "{capacity}% ´Śž",
			"format-plugged": "{capacity}% ´çŽ",
			"format-alt": "{time} {icon}",
			// "format-good": "", // An empty format will hide the module
			// "format-full": "",
			"format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
		},

		"network": {
			// "interface": "wlp2*", // (Optional) To force the use of this interface
			"format-wifi": "´çź {essid}",
			"format-ethernet": "´×ľ {ipaddr}/{cidr}",
			// "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
			"tooltip-format": "{essid}",
			"format-linked": "{ifname} (No IP) ´×ľ",
			"format-disconnected": "ÔÜá",
			// "format-alt": "{ifname}: {ipaddr}/{cidr}",
			"on-click": "alacritty -e nmtui"
		},

		"pulseaudio": {
			// "scroll-step": 1, // %, can be a float
			// "format": "{icon} {volume}% {format_source}",
			"format": "{icon}  {volume}%",
			"format-bluetooth": "{volume}% {icon}´Őö {format_source}",
			"format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
			"format-muted": "´Üę {format_source}",
			"format-source": "{volume}% ´ä░",
			"format-source-muted": "´ä▒",
			"format-icons": {
				"headphone": "´Çą",
				"hands-free": "´ľÉ",
