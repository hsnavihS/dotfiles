			},
			"on-click": "GTK_THEME=Adwaita:dark pavucontrol"
		},

		"bluetooth": {
			"format-off": "",
			"format-disabled": "",
			"format-connected": "´Őô {device_alias}",
			//"format": "´Őô {status}",
			"format": "´Őô",
			"interval": 30,
			"on-click": "GTK_THEME=Adwaita:dark blueman-manager",
			"on-click-right": "~/.config/scripts/toggle_bluetooth.sh"
		}, 

		"group/system": {
			"orientation": "horizontal",
			"modules": [
				"memory",
			"cpu"
			]
		},
}
